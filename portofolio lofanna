  <script>
    const buttons = document.querySelectorAll("[data-slide]");
    const slides = document.querySelectorAll(".slide");
    const quickLinks = document.querySelectorAll("[data-go]");

    function showSlide(id) {
      slides.forEach((slide) => {
        slide.classList.toggle("active", slide.id === id);
      });

      buttons.forEach((button) => {
        button.classList.toggle("active", button.dataset.slide === id);
      });
    }

    buttons.forEach((button) => {
      button.addEventListener("click", () => showSlide(button.dataset.slide));
    });

    quickLinks.forEach((button) => {
      button.addEventListener("click", () => showSlide(button.dataset.go));
    });
  </script>
